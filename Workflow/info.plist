				<key>script</key>
				<string># Get Selected Orion Profile
orion_path="${HOME}/Library/Application Support/Orion"
profile_id="$(plutil -convert json "${orion_path}/profiles" -o - | jq -r --arg useSelectProfile "${useSelectProfile}" '(.profiles[] | select(.name == $useSelectProfile).identifier) // .defaultProfile // "Defaults"')"
webarchive_file="${orion_path}/${profile_id}/ReadingListArchives/${id}/Page.webarchive"

# Offline article detection
[[ -f "${webarchive_file}" ]] &amp;&amp; 1="file://${webarchive_file}"
# Specify default browser for downloaded Reading List files
file_browser="$(plutil -convert json "${HOME}/Library/Preferences/com.apple.LaunchServices/com.apple.launchservices.secure.plist" -o - | jq -r '.LSHandlers[] | select(.LSHandlerURLScheme == "https").LSHandlerRoleAll')"

# Secondary browser selection
[[ "${bSecondary}" &amp;&amp; -n "${browser2}" ]] &amp;&amp; browser="${browser2}"

# Primary browser selection
[[ -z "${browser}" ]] &amp;&amp; open -b "${file_browser}" "${1}" || open -b "${browser}" "${1}"</string>
